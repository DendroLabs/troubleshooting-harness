{
  "applicable_os": [
    "sonic"
  ],
  "category": "configuration",
  "confidence": "medium",
  "def_refs": [
    "db:config_db",
    "daemon:portmgrd",
    "daemon:intfmgrd",
    "daemon:bgpcfgd"
  ],
  "prerequisites": [
    "Verify the config file is valid JSON: python3 -c \"import json; json.load(open('/etc/sonic/config_db.json'))\"",
    "Understand that unsaved running config changes will be LOST -- config reload replaces Redis with the file",
    "Plan for brief traffic disruption as services restart"
  ],
  "procedure_id": "config-reload",
  "procedure_name": "Configuration Reload",
  "purpose": "Reload configuration from /etc/sonic/config_db.json into running CONFIG_DB (Redis), restarting affected services",
  "risk_level": "medium",
  "rollback": [
    {
      "action": "Restore previous running config from backup",
      "commands": [
        {
          "command": "sudo config load /tmp/config_backup_<timestamp>.json -y",
          "os": "sonic",
          "version_range": {
            "max": "*",
            "min": "202511"
          }
        }
      ],
      "notes": "Replace <timestamp> with the backup file you created in step 1",
      "step_id": "rollback-3"
    }
  ],
  "schema_version": "1.0.0",
  "sources": [
    {
      "id": "sonic:procedures/config-reload.json",
      "title": "sonic knowledge base — procedures/config-reload.json",
      "type": "documentation"
    }
  ],
  "steps": [
    {
      "action": "Backup current running config",
      "commands": [
        {
          "command": "sudo sonic-cfggen -d --print-data > /tmp/config_backup_$(date +%Y%m%d_%H%M%S).json",
          "os": "sonic",
          "version_range": {
            "max": "*",
            "min": "202511"
          }
        }
      ],
      "next_step_id": "step-2",
      "notes": "Always backup before reload. This captures the RUNNING config, not the file.",
      "step": 1,
      "step_id": "step-1",
      "verification": [
        {
          "command": "ls -la /tmp/config_backup_*.json | tail -1",
          "confirms_if": "Backup file was created successfully",
          "look_for": "File exists with non-zero size",
          "os": "sonic",
          "version_range": {
            "max": "*",
            "min": "202511"
          }
        }
      ]
    },
    {
      "action": "Validate the config file to be loaded",
      "commands": [
        {
          "command": "python3 -c \"import json; d=json.load(open('/etc/sonic/config_db.json')); print(f'Valid JSON: {len(d)} top-level keys')\"",
          "os": "sonic",
          "version_range": {
            "max": "*",
            "min": "202511"
          }
        }
      ],
      "next_step_id": "step-3",
      "notes": "Catch JSON syntax errors before they cause a failed reload",
      "step": 2,
      "step_id": "step-2",
      "verification": [
        {
          "command": "sonic-cfggen -j /etc/sonic/config_db.json --print-data > /dev/null 2>&1 && echo 'Valid' || echo 'Invalid'",
          "confirms_if": "sonic-cfggen can parse the config file",
          "look_for": "Valid",
          "os": "sonic",
          "version_range": {
            "max": "*",
            "min": "202511"
          }
        }
      ]
    },
    {
      "action": "Execute config reload",
      "commands": [
        {
          "command": "sudo config reload -y",
          "os": "sonic",
          "version_range": {
            "max": "*",
            "min": "202511"
          }
        }
      ],
      "daemon_impact": [
        {
          "daemon": "daemon:portmgrd",
          "impact": ""
        },
        {
          "daemon": "daemon:intfmgrd",
          "impact": ""
        },
        {
          "daemon": "daemon:vlanmgrd",
          "impact": ""
        },
        {
          "daemon": "daemon:bgpcfgd",
          "impact": ""
        },
        {
          "daemon": "daemon:teammgrd",
          "impact": ""
        }
      ],
      "next_step_id": "step-4",
      "rollback_step_id": "rollback-3",
      "step": 3,
      "step_id": "step-3",
      "verification": [
        {
          "command": "show runningconfiguration all | head -5",
          "confirms_if": "Config was loaded successfully into Redis",
          "look_for": "Configuration output appears",
          "os": "sonic",
          "version_range": {
            "max": "*",
            "min": "202511"
          }
        }
      ],
      "warning": "This restarts multiple daemons. BGP will flap. Expect 10-30 seconds of disruption."
    },
    {
      "action": "Verify services recovered",
      "commands": [
        {
          "command": "show system-health summary",
          "os": "sonic",
          "version_range": {
            "max": "*",
            "min": "202511"
          }
        }
      ],
      "notes": "BGP may take 30-60 seconds to fully reconverge depending on number of peers and routes",
      "step": 4,
      "step_id": "step-4",
      "verification": [
        {
          "command": "show bgp summary; show interfaces status | head -20",
          "confirms_if": "All critical services are running and functional",
          "look_for": "BGP sessions re-established, interfaces up",
          "os": "sonic",
          "version_range": {
            "max": "*",
            "min": "202511"
          }
        }
      ]
    }
  ],
  "warnings": [
    "config reload replaces the running CONFIG_DB with the file. If you made changes and did NOT run 'config save', those changes will be lost.",
    "All *mgrd daemons will restart, causing brief service interruption",
    "BGP sessions will flap as bgpcfgd re-renders FRR config",
    "LAG/PortChannel may briefly flap as teammgrd restarts"
  ]
}
